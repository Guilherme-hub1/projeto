import numpy as np # Para trabalhar com arrays numéricos
import pandas as pd # Para organizar os dados em tabela
from sklearn.metrics.pairwise import cosine_similarity # Para calcular similaridade entre vetores
import ipywidgets as widgets # Para criar interface interativa (dropdown, botão, etc.)
from IPython.display import display, HTML # Para exibir os componentes na tela

# LEGENDA DOS GÊNEROS
# [Ação, Romance, Ficção, Comédia, Terror, Infantil]
# Base de dados
filmes = {
    "Matrix": [1, 0, 1, 0, 0, 0],
    "John Wick": [1, 0, 0, 0, 0, 0],
    "Interestelar": [0, 0, 1, 0, 0, 0],
    "Todo Mundo Odeia o Chris": [0, 0, 0, 1, 0, 0],
    "Vingadores": [1, 0, 1, 0, 0, 0],
    "Invocação do Mal": [0, 0, 0, 0, 1, 0],
    "As Branquelas": [0, 0, 0, 1, 0, 0],
    "A Proposta": [0, 1, 0, 0, 0, 0],
    "Gravidade": [0, 0, 1, 0, 0, 0],
    "It a Coisa": [0, 0, 0, 0, 1, 0],
    "A Freira": [0, 0, 0, 0, 1, 0],
    "Carros": [0, 0, 0, 0, 0, 1],
    "Toy Story": [0, 0, 0, 0, 0, 1],
    "Rio": [0, 0, 0, 0, 0, 1],
    "Alvin e os Esquilos": [0, 0, 0, 1, 0, 1],
    "Como se Fosse a Primeira Vez": [0, 1, 0, 1, 0, 0],
    "Diário de uma Paixão": [0, 1, 0, 0, 0, 0],
    "Missão Impossível": [1, 0, 0, 0, 0, 0],
    "Missão Quase Impossível": [1, 0, 0, 1, 0, 0],
    "Jurassic World Rebirth": [1, 0, 1, 0, 0, 0],
}
# Lista dos gêneros
generos = ["Ação", "Romance", "Ficção", "Comédia", "Terror", "Infantil"]

# Cria DataFrame para organizar melhor os dados
df_filmes = pd.DataFrame(filmes).T
df_filmes.columns = generos

# Lista com os nomes dos filmes
nomes = list(filmes.keys())

# Matriz com os vetores dos filmes
vetores = np.array(list(filmes.values()))

# FUNÇÃO PARA DESCOBRIR GÊNEROS EM COMUM
def generos_em_comum(vetor1, vetor2):

    comuns = []

    for i in range(len(generos)):

        # Verifica se os dois filmes possuem o mesmo gênero
        if vetor1[i] == 1 and vetor2[i] == 1:
            comuns.append(generos[i])

    return comuns

# FUNÇÃO DO BACK-END
def recomendar_filmes(filme_escolhido, top_n=5):

    # Verifica se o filme existe
    if filme_escolhido not in filmes:
        return []

    # Pega o vetor do filme escolhido e transforma em matriz
    vetor_filme_escolhido = np.array(filmes[filme_escolhido]).reshape(1,-1)

    # Calcula a similaridade entre o filme escolhido e todos os outros
    similaridades = cosine_similarity(vetor_filme_escolhido, vetores)[0]

    # Junta nome do filme com sua similaridade
    lista = list(zip(nomes, similaridades))

    # Ordena do mais parecido para o menos parecido
    ordenado = sorted(lista, key=lambda x: x[1], reverse=True)

    recomendados = []

    # Remove o próprio filme da recomendação
    # Também remove filmes com similaridade 0
    for filme, score in ordenado:

        if filme != filme_escolhido and score > 0:

            # Descobre os gêneros em comum
            comuns = generos_em_comum(
                filmes[filme_escolhido],
                filmes[filme]
            )

            recomendados.append({
                "filme": filme,
                "score": score,
                "generos": comuns
            })

    # Retorna apenas os TOP N filmes
    return recomendados[:top_n]

# FRONT-END

# Dropdown (lista suspensa) para escolher o filme
menu_filmes = widgets.Dropdown(
    options=nomes,
    description='Filme:',
    style={'description_width': 'initial'},
    layout=widgets.Layout(width='400px')
)

# Botão para gerar recomendações
botao = widgets.Button(
    description="Recomendar",
    button_style='success',
    icon='film'
)

# Área onde os resultados serão exibidos
saida = widgets.Output()

# FUNÇÃO CHAMADA QUANDO O BOTÃO É CLICADO
def clique(b):

    # Usa a área de saída
    with saida:

        # Limpa resultados anteriores
        saida.clear_output()

        # Pega o filme selecionado
        filme = menu_filmes.value

        # Chama a função de recomendação
        resultados = recomendar_filmes(filme)

        # Título estilizado
        display(HTML(f"""
        <h2 style='color:darkblue;'>
        Filmes parecidos com {filme}
        </h2>
        """))

        # Exibe os resultados
        for item in resultados:

            nome_filme = item["filme"]

            # Converte similaridade em porcentagem
            porcentagem = item["score"] * 100

            # Junta os gêneros em comum
            generos_texto = ", ".join(item["generos"])

            # Mostra na tela
            display(HTML(f"""
            <div style="
                background-color:#f4f4f4;
                padding:10px;
                margin:10px 0;
                border-radius:10px;
            ">
                <h3>{nome_filme}</h3>
                <p><b>Compatibilidade:</b> {porcentagem:.0f}%</p>
                <p><b>Gêneros em comum:</b> {generos_texto}</p>
            </div>
            """))

# Evento do botão
botao.on_click(clique)

# Exibe os componentes na tela
display(menu_filmes, botao, saida)
