import numpy as np # Para trabalhar com arrays numéricos
from sklearn.metrics.pairwise import cosine_similarity # Para calcular similaridade entre vetores
import ipywidgets as widgets # Para criar interface interativa (dropdown, botão, etc.)
from IPython.display import display # Para exibir os componentes na tela

# Base de dados
filmes = {
    "Matrix": [1, 0, 1, 0, 0, 0], # Ação=1 / Romance=0 / Ficção=1 / Comédia=0 / Terror=0 / Infantil= 0
    "John Wick": [1, 0, 0, 0, 0, 0], # Ação=1 / Romance=0 / Ficção=0 / Comédia=0 / Terror=0 / Infantil= 0
    "Interestelar": [0, 0, 1, 0, 0, 0], # Ação=0 / Romance=0 / Ficção=1 / Comédia=0 / Terror=0 / Infantil= 0
    "Todo Mundo Odeia o Chris": [0, 0, 0, 1, 0, 0], # Ação=0 / Romance=0 / Ficção=0 / Comédia=1 / Terror=0 / Infantil= 0
    "Vingadores": [1, 0, 1, 0, 0, 0],# Ação=1 / Romance=0 / Ficção=1 / Comédia=0 / Terror=0 / Infantil= 0
    "Invocação do Mal": [0, 0, 0, 0, 1, 0], # Ação=0 / Romance=0 / Ficção=0 / Comédia=0 / Terror=1 / Infantil= 0
    "As Branquelas": [0, 0, 0, 1, 0, 0], # Ação=0 / Romance=0 / Ficção=0 / Comédia=1 / Terror=0 / Infantil= 0
    "A Proposta": [0, 1, 0, 0, 0, 0], # Ação=0 / Romance=1 / Ficção=0 / Comédia=0 / Terror=0 / Infantil= 0
    "Gravidade": [0, 0, 1, 0, 0, 0], # Ação=0 / Romance=0 / Ficção=1 / Comédia=0 / Terror=0 / Infantil= 0
    "It a Coisa": [0, 0, 0, 0, 1, 0], # Ação=0 / Romance=0 / Ficção=0 / Comédia=0 / Terror=1 / Infantil= 0
    "A Freira": [0, 0, 0, 0, 1, 0], # Ação=0 / Romance=0 / Ficção=0 / Comédia=0 / Terror=1 / Infantil= 0
    "Carros": [0, 0, 0, 0, 0, 1], # Ação=0 / Romance=0 / Ficção=0 / Comédia=0 / Terror=0 / Infantil= 1
    "Toy Story": [0, 0, 0, 0, 0, 1], # Ação=0 / Romance=0 / Ficção=0 / Comédia=0 / Terror=0 / Infantil= 1
    "Rio": [0, 0, 0, 0, 0, 1], # Ação=0 / Romance=0 / Ficção=0 / Comédia=0 / Terror=0 / Infantil= 1
    "Alvin e os Esquilos": [0, 0, 0, 1, 0, 1], # Ação=0 / Romance=0 / Ficção=0 / Comédia=1 / Terror=0 / Infantil= 1
